{
  "description": "nara-kit hooks: SessionStart memory health check",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/memory-health-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
