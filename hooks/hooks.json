{
  "description": "nara-kit hooks: dev-mode review gate (blocks source commits without a fresh code review)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/nara-review-gate.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
